generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id         Int       @id @default(autoincrement())
  full_name       String    @db.VarChar(150)
  email           String    @unique @db.VarChar(150)
  github_username String?   @db.VarChar(100)
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())

  // Bổ sung các trường phục vụ Auth (Login, Google OAuth)
  password        String?
  google_id       String?   @unique
  avatar          String?

  user_roles             User_Role[]
  group_memberships      Group_Member[]
  group_leaderships      Group_Leader[]
  lecturer_assignments   Lecturer_Assignment[]
  commit_records         Commit_Record[]
  contribution_reports   Contribution_Report[]
}

model Role {
  role_id    Int    @id @default(autoincrement())
  role_name  String @unique @db.VarChar(50)

  user_roles     User_Role[]
}

model User_Role {
  user_id     Int
  role_id     Int
  assigned_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [role_id], onDelete: Cascade)

  @@id([user_id, role_id])
}

model Student_Group {
  group_id      Int      @id @default(autoincrement())
  group_name    String   @db.VarChar(100)
  semester      String   @db.VarChar(50)
  project_title String   @db.VarChar(200)
  created_at    DateTime @default(now())

  group_members          Group_Member[]
  group_leaders          Group_Leader[]
  lecturer_assignments   Lecturer_Assignment[]
  jira_project           Jira_Project?
  git_repository         Git_Repository?
  contribution_reports   Contribution_Report[]
}

model Group_Member {
  group_id  Int
  user_id   Int
  joined_at DateTime @default(now())

  student_group Student_Group @relation(fields: [group_id], references: [group_id], onDelete: Cascade)
  user          User          @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@id([group_id, user_id])
}

model Group_Leader {
  group_id    Int      @id
  user_id     Int
  assigned_at DateTime @default(now())

  student_group Student_Group @relation(fields: [group_id], references: [group_id], onDelete: Cascade)
  user          User          @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model Lecturer_Assignment {
  lecturer_id Int
  group_id    Int
  assigned_at DateTime @default(now())

  user          User          @relation(fields: [lecturer_id], references: [user_id], onDelete: Cascade)
  student_group Student_Group @relation(fields: [group_id], references: [group_id], onDelete: Cascade)

  @@id([lecturer_id, group_id])
}

model Jira_Project {
  jira_project_id Int    @id @default(autoincrement())
  group_id        Int    @unique
  project_key     String @db.VarChar(50)
  project_name    String @db.VarChar(150)
  base_url        String @db.VarChar(300)
  jira_email      String @db.VarChar(150)
  jira_api_token  String @db.VarChar(500) // Encrypted (BR-08)

  student_group Student_Group @relation(fields: [group_id], references: [group_id], onDelete: Cascade)
  jira_issues   Jira_Issue[]
}

model Jira_Issue {
  jira_issue_id   Int      @id @default(autoincrement())
  jira_project_id Int
  issue_key       String   @db.VarChar(50)
  issue_type      String   @db.VarChar(50)
  summary         String   @db.VarChar(300)
  status          String   @db.VarChar(50)
  priority        String?  @db.VarChar(50)
  assignee_email  String?  @db.VarChar(150)
  created_at      DateTime

  jira_project   Jira_Project   @relation(fields: [jira_project_id], references: [jira_project_id], onDelete: Cascade)
  commit_issues  Commit_Issue[]
}

model Git_Repository {
  repo_id   Int    @id @default(autoincrement())
  group_id  Int    @unique
  repo_name String @db.VarChar(150)
  repo_url  String @db.VarChar(300)

  student_group  Student_Group   @relation(fields: [group_id], references: [group_id], onDelete: Cascade)
  commit_records Commit_Record[]
}

model Commit_Record {
  commit_id      Int      @id @default(autoincrement())
  repo_id        Int
  author_id      Int
  commit_hash    String   @unique @db.VarChar(100)
  commit_message String?  @db.VarChar(500)
  committed_at   DateTime
  lines_added    Int      @default(0)
  lines_deleted  Int      @default(0)

  git_repository Git_Repository @relation(fields: [repo_id], references: [repo_id], onDelete: Cascade)
  author         User           @relation(fields: [author_id], references: [user_id], onDelete: Cascade)
  commit_issues  Commit_Issue[]
}

model Commit_Issue {
  commit_id     Int
  jira_issue_id Int

  commit_record Commit_Record @relation(fields: [commit_id], references: [commit_id], onDelete: Cascade)
  jira_issue    Jira_Issue    @relation(fields: [jira_issue_id], references: [jira_issue_id], onDelete: Cascade)

  @@id([commit_id, jira_issue_id])
}

model Contribution_Report {
  report_id             Int      @id @default(autoincrement())
  group_id              Int
  user_id               Int
  total_commits         Int      @default(0)
  total_issues_resolved Int      @default(0)
  total_lines_added     Int      @default(0)
  total_lines_deleted   Int      @default(0)
  calculated_at         DateTime @default(now())

  student_group Student_Group @relation(fields: [group_id], references: [group_id], onDelete: Cascade)
  user          User          @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}
